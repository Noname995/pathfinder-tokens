{
  "id": "pf2e-token-pack",
  "title": "Pathfinder 2E: Token Pack",
  "description": "Модуль добавляет изображения и токены монстрам и нпс",
  "version": "2.2.0",
  "compatibility": {
    "minimum": "12",
    "verified": "13"
  },
  "authors": [
    {
      "name": "Metofay",
      "discord": "Метофей#135975",
      "flags": {}
    }
  ],
  "esmodules": [
    "main.js",
    "character-gallery/module/main.mjs"
  ],
  "styles": [
    "character-gallery/styles/pf2e-tokens-characters.css"
  ],
  "languages": [
    {
      "lang": "ru",
      "name": "Russian",
      "path": "lang/ru.json",
      "flags": {}
    },
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json",
      "flags": {}
    }
  ],
  "flags": {
    "compendiumArtMappings": {
      "pf2e": {
      "mapping": "modules/pf2e-token-pack/bestiaries.json"
    }
  },
  "galleryDatasheets": {
      "character-gallery": {
        "label": "Pathfinder Tokens: Character Gallery Datasheet",
        "hint": "Иллюстрации из модуля Pathfinder Tokens: Character Gallery, в которых особое внимание уделяется игровым предкам для PC-персонажей и NPC-персонажей.",
        "sheet": "modules/pf2e-token-pack/character-gallery/datasheet/character-gallery.json"
      },
      "bestiaries": {
            "label": "Pathfinder Tokens: Myth and Magic Datasheet",
            "hint": "Иллюстрация из модуля Pathfinder Tokens: Myth and Magic.",
            "sheet": "modules/pf2e-token-pack/character-gallery/datasheet/myth-and-magic.json"
        }
    },
    "tokenRingSubjectMappings": {
      "modules/pf2e-tokens-characters/assets/tokens/": "modules/pf2e-token-pack/subjects/"
    }
  },
  "socket": true,

  
  "url": "https://github.com/Metofay/pf2e-token-pack",
  "manifest": "https://raw.githubusercontent.com/Metofay/pf2e-token-pack//main/module.json",
  "download": "https://github.com/Metofay/pf2e-token-pack/archive/refs/heads/main.zip",
  "readme": "https://github.com/Metofay/pf2e-token-pack/blob/main/README.md",
  "bugs": "https://github.com/Metofay/pf2e-token-pack/issues",
  "changelog": "https://github.com/Metofay/pf2e-token-pack/blob/master/CHANGELOG.md"
}