<style>
  /* Стили для DisguiseApp */
  .disguise-app-window .form-group {
    text-align: center;
  }
  .disguise-app-window .save-mode-switch {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-top: 5px;
  }
  .disguise-app-window .toggle-switch {
    position: relative;
    display: inline-block;
    width: 50px;
    height: 24px;
  }
  .disguise-app-window .toggle-switch input {
    opacity: 0;
    width: 0;
    height: 0;
  }
  .disguise-app-window .slider {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: #ccc;
    transition: 0.4s;
    border-radius: 24px;
  }
  .disguise-app-window .slider:before {
    position: absolute;
    content: '';
    height: 16px;
    width: 16px;
    left: 4px;
    bottom: 4px;
    background-color: white;
    transition: 0.4s;
    border-radius: 50%;
  }
  .disguise-app-window input:checked + .slider {
    background-color: #3f9934;
  }
  .disguise-app-window input:checked + .slider:before {
    transform: translateX(26px);
  }

  /* Стили для PhaseManagerApp (если нужны специфичные) */
  .phase-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .phase-item {
    display: flex;
    align-items: center;
    padding: 5px;
    border-bottom: 1px solid #ccc;
  }
  .phase-item img {
    width: 36px;
    height: 36px;
    object-fit: cover;
    margin-right: 10px;
    border: none;
  }
  .phase-item span {
    flex-grow: 1;
  }
  .phase-item a {
    cursor: pointer;
    margin-left: 10px;
  }
</style>

{{!-- Заголовок окна теперь полностью контролируется классом приложения (defaultOptions.title) --}}

{{#if (eq mode 'create')}}
  {{!-- Содержимое для DisguiseApp --}}
  <div style="display: flex; flex-direction: column; height: 100%;">
    {{!-- <h2 style="text-align: center;">{{i18n.appCreateNewDisguise}}</h2> --}} {{!-- Удалено --}}
    <div class="form-group">
      <label style="font-weight: bold;">{{i18n.appMode}}</label>
      <div class="save-mode-switch">
        <span>{{i18n.appHybrid}}</span>
        <label class="toggle-switch">
          <input type="checkbox" id="save-mode-toggle" name="save-mode" />
          <span class="slider"></span>
        </label>
        <span>{{i18n.appFullCopy}}</span>
      </div>
    </div>
    <p style="text-align: center; margin: 10px 0;">{{i18n.appModeNotes}}</p>
    <div
      class="drop-target"
      style="
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        border: 2px dashed #666;
        border-radius: 5px;
      "
    >
      <label style="font-weight: bold; font-size: 14px;">{{i18n.appDragActorHere}}</label>
      <i class="fas fa-file-import fa-3x" style="color: #666; margin-top: 10px;"></i>
    </div>
  </div>
{{else if (eq mode 'manage')}}
  {{!-- Содержимое для PhaseManagerApp --}}
  {{!-- <h2 style="text-align: center;">{{i18n.managerTitle}}</h2> --}} {{!-- Удалено --}}
  <ul class="phase-list">
    {{#if hybrids}}
      <h3 style="text-align: center; border-bottom: 1px solid #ccc; margin: 10px 0 5px 0; font-size: 16px;">
        {{i18n.hybridSkins}}
      </h3>
    {{/if}}
    {{#each hybrids}}
      <li class="phase-item" data-id="{{id}}" data-type="{{type}}">
        <img
          src="{{img}}"
          style="width: 36px; height: 36px; object-fit: cover; margin-right: 10px; border: none;"
        />
        <span style="flex-grow: 1;">{{name}}</span>
        <a class="apply-phase" title="{{i18n.apply}}">
          <i class="fas fa-play"></i>
        </a>
        {{#if (and (not isOriginal) (eq type 'full'))}}
          <a class="edit-phase" title="{{i18n.edit}}">
            <i class="fas fa-edit"></i>
          </a>
        {{/if}}
        {{#unless isOriginal}}
          <a class="delete-phase" title="{{i18n.delete}}">
            <i class="fas fa-trash"></i>
          </a>
        {{/unless}}
      </li>
    {{/each}}

    {{#if fulls}}
      <h3 style="text-align: center; border-bottom: 1px solid #ccc; margin: 10px 0 5px 0; font-size: 16px;">
        {{i18n.fullPhases}}
      </h3>
    {{/if}}
    {{#each fulls}}
      <li class="phase-item" data-id="{{id}}" data-type="{{type}}">
        <img
          src="{{img}}"
          style="width: 36px; height: 36px; object-fit: cover; margin-right: 10px; border: none;"
        />
        <span style="flex-grow: 1;">{{name}}</span>
        <a class="apply-phase" title="{{i18n.apply}}">
          <i class="fas fa-play"></i>
        </a>
        {{#if (and (not isOriginal) (eq type 'full'))}}
          <a class="edit-phase" title="{{i18n.edit}}">
            <i class="fas fa-edit"></i>
          </a>
        {{/if}}
        {{#unless isOriginal}}
          <a class="delete-phase" title="{{i18n.delete}}">
            <i class="fas fa-trash"></i>
          </a>
        {{/unless}}
      </li>
    {{/each}}

    {{#unless hasDisguises}}
      <li style="padding: 10px; text-align: center;">{{i18n.noSavedDisguises}}</li>
    {{/unless}}
  </ul>
{{/if}}