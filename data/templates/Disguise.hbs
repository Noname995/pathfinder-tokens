{{!-- ###################################################################### --}}
{{!-- #####          ШАБЛОН ДЛЯ МЕНЕДЖЕРА ОБРАЗОВ (PhaseManagerApp)          ##### --}}
{{!-- ###################################################################### --}}
{{#if isManager}}
<ul class="phase-list" style="list-style:none;padding:0;margin:0;">
    {{!-- Проверяем, есть ли вообще что-то в списках --}}
    {{#if (or hybrids.length fulls.length)}}

        {{!-- Если есть гибридные образы, выводим их --}}
        {{#if hybrids.length}}
            <h3 class="list-header">{{localize "Disguise.HybridSkinsHeader"}}</h3>
            {{#each hybrids}}
            <li class="phase-item {{#if this.isActive}}active{{/if}}" data-id="{{this.id}}" data-type="{{this.type}}">
                <img src="{{this.img}}" class="phase-icon"/>
                <span class="phase-name">{{this.name}}</span>
                <a class="apply-phase" title="{{localize 'Disguise.ApplyTitle'}}"><i class="fas fa-play"></i></a>
                <a class="delete-phase" title="{{localize 'Disguise.DeleteTitle'}}"><i class="fas fa-trash"></i></a>
            </li>
            {{/each}}
        {{/if}}

        {{!-- Если есть полные копии, выводим их --}}
        {{#if fulls.length}}
            <h3 class="list-header">{{localize "Disguise.FullCopiesHeader"}}</h3>
            {{#each fulls}}
            <li class="phase-item {{#if this.isActive}}active{{/if}}" data-id="{{this.id}}" data-type="{{this.type}}">
                <img src="{{this.img}}" class="phase-icon"/>
                <span class="phase-name">{{this.name}}</span>
                <a class="apply-phase" title="{{localize 'Disguise.ApplyTitle'}}"><i class="fas fa-play"></i></a>
                <a class="edit-phase" title="{{localize 'Disguise.EditTitle'}}"><i class="fas fa-edit"></i></a>
                <a class="delete-phase" title="{{localize 'Disguise.DeleteTitle'}}"><i class="fas fa-trash"></i></a>
            </li>
            {{/each}}
        {{/if}}

    {{else}}
        {{!-- Этот блок сработает, только если оба списка пусты --}}
        <li style="padding:10px;text-align:center;">{{localize "Disguise.NoSavedDisguises"}}</li>
    {{/if}}
</ul>


{{!-- ###################################################################### --}}
{{!-- #####          ШАБЛОН ДЛЯ ДИАЛОГА СОХРАНЕНИЯ (Dialog)                ##### --}}
{{!-- ###################################################################### --}}
{{else if isPrompt}}
<p>{{{dialogText}}}</p>
<form>
    <div class="form-group">
        <label>{{localize "Disguise.NameLabel"}}</label>
        <input type="text" name="disguiseName" value="{{disguiseName}}"/>
    </div>
</form>


{{!-- ###################################################################### --}}
{{!-- #####          ШАБЛОН ДЛЯ СОЗДАНИЯ ОБРАЗА (DisguiseApp)                ##### --}}
{{!-- ###################################################################### --}}
{{else}}
<form>
    {{!-- ИЗМЕНЕНИЯ ЗДЕСЬ: Заголовок и переключатель разделены на независимые блоки --}}

    {{!-- Блок 1: Заголовок --}}
    <div class="form-group" style="text-align: center; margin-bottom: 5px;">
        <p style="font-weight: bold; margin: 0;">{{localize "Disguise.Step1Mode"}}</p>
    </div>

    {{!-- Блок 2: Переключатель --}}
    <div class="form-group" style="text-align: center;">
        <div class="save-mode-switch" style="display:flex;align-items:center;justify-content:center;gap:10px;">
            <span>{{localize "Disguise.HybridMode"}}</span>
            <label class="toggle-switch">
                <input type="checkbox" id="save-mode-toggle" name="save-mode"/>
                <span class="slider"></span>
            </label>
            <span>{{localize "Disguise.FullCopyMode"}}</span>
        </div>
    </div>
    
    {{!-- КОНЕЦ ИЗМЕНЕНИЙ --}}

    <p class="notes" style="text-align:center;margin:15px 0;">
        {{localize "Disguise.SelectModeThenDrag"}}
    </p>

    <div class="drop-target" style="height: 150px; display:flex;flex-direction:column;justify-content:center;align-items:center;border:2px dashed #666;border-radius:5px;">
        <label style="font-weight:bold;font-size:14px;">{{localize "Disguise.Step2DragActor"}}</label>
        <i class="fas fa-file-import fa-3x" style="color:#666;margin-top:10px;"></i>
    </div>
</form>
{{/if}}


{{!-- ###################################################################### --}}
{{!-- #####                         ОБЩИЕ СТИЛИ                          ##### --}}
{{!-- ###################################################################### --}}
<style>
    /* Стили для Менеджера Образов */
    .phase-list .list-header { text-align:center;border-bottom:1px solid #ccc;margin:10px 0 5px 0;font-size:16px; }
    .phase-list .phase-item { display:flex;align-items:center;padding:5px;border-bottom:1px solid #ccc; border-left: 3px solid transparent; }
    .phase-list .phase-item.active { background-color: rgba(40, 167, 69, 0.5); border-left: 3px solid #28a745; font-weight: bold; }
    .phase-list .phase-icon { width:36px;height:36px;object-fit:cover;margin-right:10px;border:none; }
    .phase-list .phase-name { flex-grow:1; }
    .phase-list .phase-item a { cursor:pointer; margin-left: 10px; }
    .phase-list {
        max-height: 440px; /* Немного меньше высоты окна, чтобы учесть заголовок */
        overflow-y: auto;  /* Полоса прокрутки появится автоматически, когда нужно */
    }
    .phase-list .list-header { text-align:center;border-bottom:1px solid #ccc;margin:10px 0 5px 0;font-size:16px; }
    .phase-list .phase-item { display:flex;align-items:center;padding:5px;border-bottom:1px solid #ccc; border-left: 3px solid transparent; }

    /* Стили для Окна Создания */
    .disguise-app-window .toggle-switch{position:relative;display:inline-block;width:50px;height:24px;}
    .disguise-app-window .toggle-switch input{opacity:0;width:0;height:0;}
    .disguise-app-window .slider{position:absolute;cursor:pointer;top:0;left:0;right:0;bottom:0;background-color:#ccc;transition:.4s;border-radius:24px;}
    .disguise-app-window .slider:before{position:absolute;content:"";height:16px;width:16px;left:4px;bottom:4px;background-color:white;transition:.4s;border-radius:50%;}
    .disguise-app-window input:checked+.slider{background-color:#3f9934;}
    .disguise-app-window input:checked+.slider:before{transform:translateX(26px);}
</style>